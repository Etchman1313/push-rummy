# Copy to .env in the project root (do not commit .env).
# Used by docker compose and optional local tooling.

# Required for Docker / NODE_ENV=production (min 32 chars, unique per deployment)
JWT_SECRET=

# Optional: exactly one login username (case-insensitive) that may use Developer Home in the UI.
# Not embedded in the client bundle; set on the server only.
# DEVELOPER_USERNAME=

# Optional: restrict browser origins (comma-separated). Unset = wildcard CORS.
# CORS_ORIGIN=https://your-host.example.com

# Optional: enables POST /admin/reset-db with header x-admin-key
# ADMIN_RESET_KEY=

# Local dev only (optional): strong key if you test admin reset
# ADMIN_RESET_KEY=your-local-reset-secret

# Behind Traefik/nginx: improves rate-limit client IP when TRUST_PROXY=1 is set on server
# (Set on server process / compose, not only in this file, if you run without compose.)
